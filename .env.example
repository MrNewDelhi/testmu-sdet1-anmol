# Copy to .env for local runs. Never commit real secret values.

# xAI powers self-healing (v1-v6) and the failure explainer (v7-v8).
XAI_API_KEY=
XAI_MODEL=grok-4.3
# Model for multimodal (screenshot) failure analysis. Defaults to XAI_MODEL;
# override only if your main model lacks vision support.
XAI_VISION_MODEL=grok-4.3
# Set to 1 to echo every xAI call (latency/status/tokens) to stderr.
# XAI_DEBUG=1

# Local demo page used by the v1 self-healing test.
BASE_URL=http://127.0.0.1:9323

# Assignment targets.
WEB_BASE_URL=https://ecommerce-playground.lambdatest.io
API_BASE_URL=https://restful-booker.herokuapp.com
