{
  "name": "testmu-sdet1-anmol",
  "version": "0.1.0",
  "private": false,
  "description": "TestMu SDET-1 assessment scaffold using TypeScript and Playwright.",
  "scripts": {
    "test": "playwright test",
    "test:self-healing": "playwright test tests/demo tests/framework",
    "test:self-healing:v1": "playwright test tests/demo/self-healing-v1-demo.spec.ts",
    "test:self-healing:v2": "playwright test tests/demo/self-healing-v2-centralized.spec.ts",
    "test:self-healing:v3": "playwright test tests/demo/self-healing-v3-confidence-cache.spec.ts",
    "test:self-healing:v4": "playwright test tests/demo/self-healing-v4-contract.spec.ts",
    "test:self-healing:v5": "playwright test tests/demo/self-healing-v5-deterministic.spec.ts",
    "test:self-healing:v6": "playwright test tests/demo/self-healing-v6-multi-locator.spec.ts",
    "test:self-healing:v7": "playwright test -c playwright.failure-demo.config.ts",
    "test:self-healing:v9": "FAILURE_ANALYSIS_MODE=b playwright test -c playwright.failure-demo.config.ts",
    "test:generated:run": "playwright test tests/login/generated-login.spec.ts tests/dashboard/generated-dashboard.spec.ts tests/api/generated-api.spec.ts",
    "test:generated:list": "tsx scripts/list-generated-cases.ts",
    "test:login": "playwright test tests/login",
    "test:dashboard": "playwright test tests/dashboard",
    "test:api": "playwright test tests/api",
    "serve:demo": "tsx scripts/serve-public.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
